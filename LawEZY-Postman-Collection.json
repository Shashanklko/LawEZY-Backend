	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstname\": \"Shashank\",\n    \"lastname\": \"Singh\",\n    \"email\": \"shashank@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"USER\"\n}"
						},
						"url": { "raw": "http://localhost:8080/api/auth/register", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "register"] }
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"shashank\",\n    \"password\": \"password123\"\n}"
						},
						"url": { "raw": "http://localhost:8080/api/auth/login", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
					}
				}
			]
		},
		{
			"name": "2. LexBot AI Assistant",
			"item": [
				{
					"name": "Ask LexBot",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"What are the rules for divorce in the hub?\"\n}"
						},
						"url": { "raw": "http://localhost:8080/api/ai/ask", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "ai", "ask"] }
					}
				}
			]
		},
		{
			"name": "3. Community & Social",
			"item": [
				{
					"name": "Get Community Feed",
					"request": {
						"method": "GET",
						"url": { 
							"raw": "http://localhost:8080/api/community/feed?type=BLOG", 
							"protocol": "http", 
							"host": ["localhost"], 
							"port": "8080", 
							"path": ["api", "community", "feed"],
							"query": [ { "key": "type", "value": "BLOG" } ]
						}
					}
				},
				{
					"name": "Create Community Post",
					"request": {
						"method": "POST",
						"url": { 
							"raw": "http://localhost:8080/api/community/posts?authorId=1&title=Legal Tech&content=The future of AI in law is bright.&type=BLOG", 
							"protocol": "http", 
							"host": ["localhost"], 
							"port": "8080", 
							"path": ["api", "community", "posts"],
							"query": [ 
								{ "key": "authorId", "value": "1" },
								{ "key": "title", "value": "Legal Tech" },
								{ "key": "content", "value": "The future of AI in law is bright." },
								{ "key": "type", "value": "BLOG" }
							]
						}
					}
				}
			]
		},
		{
			"name": "4. Consultation (Chat)",
			"item": [
				{
					"name": "Start Chat Session",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": 1,\n    \"lawyerId\": 2\n}"
						},
						"url": { "raw": "http://localhost:8080/api/chat/start", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "chat", "start"] }
					}
				},
				{
					"name": "Get Chat History",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8080/api/chat/session-1/history", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "chat", "session-1", "history"] }
					}
				}
			]
		},
		{
